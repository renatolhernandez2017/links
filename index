<!doctype html>
<html lang="pt-BR" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meus Links</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Outfit', sans-serif; }
    .link-btn {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .link-btn:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);
    }
    .link-btn:active { transform: translateY(0) scale(0.98); }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-in { animation: fadeUp 0.6s ease forwards; opacity: 0; }
    .avatar-ring {
      background: conic-gradient(from 0deg, #f59e0b, #ef4444, #ec4899, #8b5cf6, #3b82f6, #f59e0b);
      padding: 3px;
      border-radius: 9999px;
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full">
  <div id="app" class="w-full h-full overflow-auto flex justify-center" style="background: #0f0f0f;">
   <div class="w-full max-w-md px-6 py-12 flex flex-col items-center"><!-- Avatar -->
    <div class="avatar-ring mb-4 animate-in" style="animation-delay: 0.1s;">
     <div class="w-24 h-24 rounded-full flex items-center justify-center text-3xl" style="background: #1a1a2e;">
      👤
     </div>
    </div><!-- Name -->
    <h1 id="profile-name" class="text-2xl font-bold mb-1 animate-in" style="color: #ffffff; animation-delay: 0.2s;">Seu Nome</h1>
    <p id="profile-bio" class="text-sm mb-8 animate-in" style="color: #a0a0a0; animation-delay: 0.3s;">Criador de conteúdo ✨</p><!-- Links -->
    <div id="links-container" class="w-full flex flex-col gap-4">
    </div><!-- Footer -->
    <p class="mt-10 text-xs" style="color: #555;">Feito com ❤️</p>
   </div>
  </div>
  <script>
    const defaultConfig = {
      background_color: '#0f0f0f',
      button_color: '#1e1e3a',
      text_color: '#ffffff',
      accent_color: '#a78bfa',
      subtle_color: '#a0a0a0',
      font_family: 'Outfit',
      font_size: 16,
      profile_name: 'Seu Nome',
      profile_bio: 'Criador de conteúdo ✨',
      link1_text: '🌐 Meu Site',
      link1_url: 'https://example.com',
      link2_text: '▶️ YouTube',
      link2_url: 'https://youtube.com',
      link3_text: '🛒 Loja Online',
      link3_url: 'https://example.com/loja',
      link4_text: '💬 WhatsApp',
      link4_url: 'https://wa.me/5500000000000',
      link5_text: '🎵 TikTok',
      link5_url: 'https://tiktok.com',
    };

    function renderLinks(config) {
      const container = document.getElementById('links-container');
      container.innerHTML = '';
      const links = [
        { text: config.link1_text, url: config.link1_url },
        { text: config.link2_text, url: config.link2_url },
        { text: config.link3_text, url: config.link3_url },
        { text: config.link4_text, url: config.link4_url },
        { text: config.link5_text, url: config.link5_url },
      ];
      links.forEach((link, i) => {
        if (!link.text && !link.url) return;
        const a = document.createElement('a');
        a.href = link.url || '#';
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'link-btn w-full py-4 px-6 rounded-2xl text-center font-medium animate-in';
        a.style.background = config.button_color || defaultConfig.button_color;
        a.style.color = config.text_color || defaultConfig.text_color;
        a.style.animationDelay = `${0.4 + i * 0.1}s`;
        a.style.fontSize = `${config.font_size || defaultConfig.font_size}px`;
        a.style.fontFamily = `${config.font_family || defaultConfig.font_family}, sans-serif`;
        a.style.border = `1px solid ${config.accent_color || defaultConfig.accent_color}33`;
        a.textContent = link.text || `Link ${i + 1}`;
        container.appendChild(a);
      });
    }

    async function onConfigChange(config) {
      const c = { ...defaultConfig, ...config };
      document.getElementById('app').style.background = c.background_color;
      document.getElementById('profile-name').textContent = c.profile_name;
      document.getElementById('profile-name').style.color = c.text_color;
      document.getElementById('profile-name').style.fontFamily = `${c.font_family}, sans-serif`;
      document.getElementById('profile-name').style.fontSize = `${c.font_size * 1.5}px`;
      document.getElementById('profile-bio').textContent = c.profile_bio;
      document.getElementById('profile-bio').style.color = c.subtle_color;
      document.getElementById('profile-bio').style.fontFamily = `${c.font_family}, sans-serif`;
      document.getElementById('profile-bio').style.fontSize = `${c.font_size * 0.875}px`;
      renderLinks(c);
    }

    window.elementSdk.init({
      defaultConfig,
      onConfigChange,
      mapToCapabilities: (config) => ({
        recolorables: [
          { get: () => config.background_color || defaultConfig.background_color, set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
          { get: () => config.button_color || defaultConfig.button_color, set: (v) => { config.button_color = v; window.elementSdk.setConfig({ button_color: v }); } },
          { get: () => config.text_color || defaultConfig.text_color, set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
          { get: () => config.accent_color || defaultConfig.accent_color, set: (v) => { config.accent_color = v; window.elementSdk.setConfig({ accent_color: v }); } },
          { get: () => config.subtle_color || defaultConfig.subtle_color, set: (v) => { config.subtle_color = v; window.elementSdk.setConfig({ subtle_color: v }); } },
        ],
        borderables: [],
        fontEditable: { get: () => config.font_family || defaultConfig.font_family, set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); } },
        fontSizeable: { get: () => config.font_size || defaultConfig.font_size, set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); } },
      }),
      mapToEditPanelValues: (config) => new Map([
        ['profile_name', config.profile_name || defaultConfig.profile_name],
        ['profile_bio', config.profile_bio || defaultConfig.profile_bio],
        ['link1_text', config.link1_text || defaultConfig.link1_text],
        ['link1_url', config.link1_url || defaultConfig.link1_url],
        ['link2_text', config.link2_text || defaultConfig.link2_text],
        ['link2_url', config.link2_url || defaultConfig.link2_url],
        ['link3_text', config.link3_text || defaultConfig.link3_text],
        ['link3_url', config.link3_url || defaultConfig.link3_url],
        ['link4_text', config.link4_text || defaultConfig.link4_text],
        ['link4_url', config.link4_url || defaultConfig.link4_url],
        ['link5_text', config.link5_text || defaultConfig.link5_text],
        ['link5_url', config.link5_url || defaultConfig.link5_url],
      ]),
    });
  </script>
